# Copy this file to `.env` for local dev, or paste these vars into Railway's
# (or your platform's) environment-variables panel for deployed instances.
# Never commit a real `.env`.

# ─── LLM provider ─────────────────────────────────────────────────────────
# Get one at console.anthropic.com — set a monthly spending cap there too.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Database (Pagila on Neon or compatible Postgres) ────────────────────
# Read-only role used by the running agent. Statement timeout enforced
# server-side per the connection-init hook in agent/db.py.
DATABASE_URL_AGENT=postgresql://report_agent:...@host/db?sslmode=require

# Read-write role — local dev only. Used by tools that mutate the DB
# (RAG indexer, schema migrations). DO NOT set this in prod env.
DATABASE_URL_ADMIN=postgresql://admin_user:...@host/db?sslmode=require

# ─── RAG embedding provider ──────────────────────────────────────────────
# Get one at dashboard.voyageai.com. Free tier is 3 RPM (rate-limits
# parallel report retrievals); add a payment method to unlock standard limits.
VOYAGE_API_KEY=pa-...

# ─── Tracing (optional but recommended) ──────────────────────────────────
# Free tier covers ~5K traces/month at smith.langchain.com.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=data-reporting-agent

# ─── App auth ─────────────────────────────────────────────────────────────
# Single shared username/password gate (see app.py _auth_callback).
# Generate the secret with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
CHAINLIT_AUTH_SECRET=replace-with-random-string-from-secrets-token_urlsafe
APP_USERNAME=demo
APP_PASSWORD=replace-with-strong-password
